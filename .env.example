DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Use a direct (non-pooled) Postgres URL for migrations. On Supabase, use the session/direct connection (port 5432), not the pooler (6543). For local Postgres, set this the same as DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_SESSION_SECRET="change-this-to-a-long-random-string"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Local/dev only. Enables the Test payment option in checkout.

# Used to encrypt payment credentials saved from Admin. Keep stable and private.
PAYMENT_SETTINGS_ENCRYPTION_KEY="change-this-to-a-long-random-secret"
